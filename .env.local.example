# Copy to .env.local and fill in your values

# Optional: full URL to intro MP4 (host on Supabase Storage, Cloudflare R2, S3, etc.)
# If unset, the app uses public/achievements/intro.mp4 → /achievements/intro.mp4
# NEXT_PUBLIC_INTRO_VIDEO_URL=https://your-project.supabase.co/storage/v1/object/public/bucket/intro.mp4

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Server-only: bypass RLS for some routes when team code is verified (Supabase Dashboard → Settings → API)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Server-only; used by /api/verify-code
PIRATES_SECURITY_CODE=Pirates102
# Optional: HMAC secret for one-time team-code handoff tokens (defaults to PIRATES_SECURITY_CODE if unset)
# PIRATES_TEAM_HANDOFF_SECRET=long-random-string
# Optional override for admin code (defaults in code if unset)
# PIRATES_ADMIN_CODE=#Pirateswinners1
OPENWEATHER_API_KEY=your-openweather-api-key
